# =======================
# Emontic AI .gitignore
# =======================

# -----------------------
# Node / Frontend (React/Vite)
# -----------------------
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------
# Python / Backend (FastAPI)
# -----------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
backend/models/
backend/uploads/
*.db

# --------------------------
# Virtual Environments
# --------------------------
.env
.env.local
.env.*.local
.venv
venv/
ENV/
env.bak/
venv.bak/

# ---------------------------
# Deep Learning / Training
# ---------------------------
# Datasets
datasets/

# Training Logs & Checkpoints
training/logs/
training/checkpoints/

# Exported Models
saved_model/*
!saved_model/*.md
!saved_model/*.json
*.h5
*.keras
*.hdf5
*.pb
*.tflite
*.pt
*.pth
*.onnx

# ---------------------------
# IDEs and OS
# ---------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

